{
  "name": "price.repository",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "tsx --env-file=.env src/dev/local-chat.ts",
    "build": "tsup src/server.ts --format esm --clean --minify",
    "start": "node .",
    "supabase": "npx supabase --workdir=src",
    "supabase:start": "npm run supabase -- start --exclude=realtime,logflare,imgproxy,supavisor,vector",
    "supabase:stop": "npm run supabase -- stop --all",
    "supabase:status": "npm run supabase -- status",
    "supabase:generate:types": "npm run --silent supabase -- gen types --local > src/supabase/database.types.ts",
    "supabase:db:diff": "npm run supabase -- db diff --local",
    "supabase:db:reset": "npm run supabase -- db reset --local",
    "supabase:migration:new": "npm run supabase -- migration new",
    "supabase:migration:list": "npm run supabase -- migration list --local",
    "supabase:migration:up": "npm run supabase -- migration up --local",
    "supabase:migration:down": "npm run supabase -- migration down --local"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafhael-galvao/price.repository.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/rafhael-galvao/price.repository/issues"
  },
  "homepage": "https://github.com/rafhael-galvao/price.repository#readme",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "supabase": "^2.93.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@supabase/supabase-js": "^2.99.0",
    "fastify": "^5.8.2",
    "fastify-type-provider-zod": "^6.1.0",
    "http-status-codes": "^2.3.0",
    "zod": "^4.3.6"
  }
}
