# App config
NODE_ENV=development
PORT=3000

# Meta webhook config
META_WEBHOOK_VERIFY_TOKEN=change-me
META_WHATSAPP_API_VERSION=21.0

# Official channel -> prod services
WHATSAPP_OFFICIAL_PHONE_NUMBER_ID=
WHATSAPP_OFFICIAL_ACCESS_TOKEN=
OFFICIAL_SUPABASE_URL=
OFFICIAL_SUPABASE_SERVICE_ROLE_KEY=

# Test channel -> staging services
WHATSAPP_TEST_PHONE_NUMBER_ID=
WHATSAPP_TEST_ACCESS_TOKEN=
TEST_SUPABASE_URL=
TEST_SUPABASE_SERVICE_ROLE_KEY=

# Local development -> local Supabase + mock WhatsApp delivery
LOCAL_SUPABASE_URL=http://127.0.0.1:54321
LOCAL_SUPABASE_SERVICE_ROLE_KEY=
LOCAL_MOCK_PHONE_NUMBER_ID=local-dev-phone-number-id
LOCAL_MOCK_RECIPIENT_PHONE=5511999999999
